{
  "name": "hekayati",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "app": "npm run build && tsx src/server/index.ts",
    "app:test": "HEKAYATI_DATA_DIR=.tmp/e2e HEKAYATI_PORT=4317 HEKAYATI_TEST_ROUTES=1 HEKAYATI_NO_OPEN=1 tsx src/server/index.ts",
    "build": "npm run typecheck && vite build",
    "check": "npm run lint && npm run check:fonts && npm run typecheck && npm run test",
    "check:fonts": "node scripts/check-ui-fonts.mjs",
    "check:size": "node scripts/check-file-size.mjs",
    "coverage": "vitest run --coverage",
    "fetch:fonts": "node scripts/fetch-ui-fonts.mjs",
    "format": "prettier --write src tests scripts *.config.ts package.json tsconfig.json",
    "format:check": "prettier --check src tests scripts *.config.ts package.json tsconfig.json",
    "lint": "eslint src tests *.config.ts && npm run check:size",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/multipart": "10.1.0",
    "@fastify/static": "10.1.0",
    "better-sqlite3": "12.11.1",
    "fastify": "5.10.0",
    "file-type": "22.0.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "sharp": "0.35.3",
    "ulid": "3.0.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "22.20.1",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.7.0",
    "jiti": "2.7.0",
    "prettier": "3.9.5",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}

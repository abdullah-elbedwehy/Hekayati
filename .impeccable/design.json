  "narrative": {
    "northStar": "Citrus Playground workshop: gift energy on identity moments, calm clarity in operator chrome.",
    "overview": "Canonical kit is brand-kits/02-citrus-playground.html. Scene: an employee building gift books on a bright Mac desk by day; the UI should feel like a sunlit workshop with citrus energy, not a dark ops console and not a toy store explosion. Product chrome defaults to Restrained (paper, ink, leaf actions). Brand moments may go Committed with leaf fields plus lemon/orange accents.",
    "keyCharacteristics": [
      "RTL-first Arabic product UI",
      "Lemonada for brand/display only",
      "Source Sans 3 for all operator chrome",
      "Leaf primary, orange warning, lemon signal",
      "Tonal elevation over heavy shadows",
      "One citrus system for Books and Studio"
    ],
    "rules": [
      {
        "name": "Operator First",
        "body": "Every screen serves a production task; decoration never blocks scanning, queues, or errors.",
        "section": "overview"
      },
      {
        "name": "Gift Energy, Workshop Clarity",
        "body": "Spend citrus on logo, ending page, watermark, empty states, Studio header; keep working chrome calm.",
        "section": "colors"
      },
      {
        "name": "Display Font Discipline",
        "body": "Never put Lemonada on table headers, form labels, or dense controls.",
        "section": "typography"
      }
    ],
    "dos": [
      "Load /impeccable context (PRODUCT.md + DESIGN.md) and /frontend-design before any frontend UI work",
      "Keep operator chrome restrained; spend citrus on identity and attention",
      "Design RTL first; mirror logic, not just text alignment",
      "Use Lemonada sparingly for brand moments",
      "Match kit 02 swatches exactly unless amending DESIGN.md"
    ],
    "donts": [
      "Introduce purple, indigo SaaS gradients, or cream+terracotta editorial kits",
      "Use Inter / Roboto / Arial / Space Grotesk as primary UI fonts",
      "Put Lemonada on table headers, form labels, or dense controls",
